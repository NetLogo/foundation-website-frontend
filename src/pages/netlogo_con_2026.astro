---
import Layout from "../layouts/Layout.astro";
import { AboutSection } from "../components/about/about-page";
import NetLogoAPI from "../utils/api";

const api = new NetLogoAPI();
const conferenceData = await api.getNetLogoCon2026Content();
---

<Layout
    title="NetLogo Conference 2026"
    description="NetLogo Conference 2026 Information"
>
    <AboutSection AboutData={conferenceData} client:load />
</Layout>
